                                "key": "Authorization",
                                "value": "Bearer {{access_token}}"
                            },
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"title\": \"Advanced Python v2\"\n}"
                        },
                        "url": {
                            "raw": "{{base_url}}/courses/1",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "courses",
                                "1"
                            ]
                        }
                    }
                },
                {
                    "name": "Delete Course (Admin Only)",
                    "request": {
                        "method": "DELETE",
                        "header": [
