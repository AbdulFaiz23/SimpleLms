                                "key": "Authorization",
                                "value": "Bearer {{access_token}}"
                            }
                        ],
                        "url": {
                            "raw": "{{base_url}}/courses/1",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "courses",
                                "1"
                            ]
                        }
                    }
                },
                {
                    "name": "Create Lesson (Owner/Admin)",
                    "request": {
                        "method": "POST",
                        "header": [],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"title\": \"New Lesson\",\n    \"order\": 1\n}",
                            "options": {
                                "raw": {
                                    "language": "json"
                                }
                            }
                        },
                        "url": {
                            "raw": "{{base_url}}/api/courses/1/lessons",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "courses",
                                "1",
                                "lessons"
                            ]
                        }
                    },
                    "response": []
                },
                {
                    "name": "List Lessons (Public)",
                    "request": {
                        "method": "GET",
                        "header": [],
                        "url": {
                            "raw": "{{base_url}}/api/courses/1/lessons",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "courses",
                                "1",
                                "lessons"
                            ]
                        }
                    },
                    "response": []
                }
            ]
        },
