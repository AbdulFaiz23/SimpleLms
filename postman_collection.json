        {
            "name": "Tasks",
            "item": [
                {
                    "name": "Export Course Report",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "const data = pm.response.json();",
                                    "if (data.task_id) {",
                                    "    pm.collectionVariables.set(\"task_id\", data.task_id);",
                                    "}"
                                ],
                                "type": "text/javascript"
                            }
                        }
                    ],
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{access_token}}"
                            }
                        ],
                        "url": {
                            "raw": "{{base_url}}/courses/{{course_id}}/export-report",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "courses",
                                "{{course_id}}",
                                "export-report"
                            ]
                        }
                    }
                },
